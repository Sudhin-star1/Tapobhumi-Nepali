NODE_ENV=development
HOST=0.0.0.0
PORT=5000

# IMPORTANT: put your real Atlas URI here (do NOT commit it)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Use a long random secret in production
JWT_SECRET=please_change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Comma-separated or "*" for local dev
CORS_ORIGIN=http://localhost:8080

# Cloudinary (required for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: override default seeded admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!

